# 忽略CLIP预训练
# 执行以下，即下载预训练的CLIP模型：
# cd /hy-tmp/PG-MoE_0124 && mkdir pretrained_models
# oss cp oss://datasets/open_clip_pytorch_model.bin.zip /hy-tmp/PG-MoE_0124/pretrained_models/
# cd pretrained_models && mv open_clip_pytorch_model.bin.zip open_clip_pytorch_model.bin

# 整体架构：
# PG-MOE-Project/
# ├── code/    
# ├── datasets/                  # [需要重新下载/上传] 存放所有训练和测试数据
# │   └── dataset-A/
# └── pretrained_models/         # [需要重新下载/上传] 存放预训练模型权重
#     └── open_clip_pytorch_model.bin # 约 1.2 GB，从 Hugging Face 下载

# 仅保留datasets目录
datasets/*
!datasets/单独下载数据集.txt

# 忽略所有训练结果和模型
results/

# 忽略大文件
*.bin
*.pth
*.tar.gz
*.zip
*.zst

# 仅保留pretrained_models目录
pretrained_models/*
!pretrained_models/单独下载CLIP模型.txt

# 忽略code目录下的日志文件
code/*.txt

# 忽略 Python 缓存文件
__pycache__/
*.pyc

# 忽略 Conda/Python 虚拟环境文件夹 (如果创建在项目内)
pg_moe/
.env
env/
venv/

# 忽略 IDE 的配置文件
.vscode/
.idea/